{
  "name": "@realtimeregister/api",
  "private": false,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite build --mode dev --watch ",
    "build": "tsc --noEmit && vite build --mode prod",
    "preview": "pnpm run build && yalc push",
    "preview:dev": "vite build --mode dev && yalc push",
    "lint": "eslint",
    "lint:fix": "eslint --fix"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/realtimeregister/realtimeregister-ts.git"
  },
  "homepage": "https://github.com/realtimeregister/realtimeregister-ts#readme",
  "bugs": {
    "url": "https://github.com/realtimeregister/realtimeregister-ts/issues"
  },
  "keywords": [
    "realtimeregister",
    "domains",
    "ssl"
  ],
  "files": [
    "dist"
  ],
  "license": "MIT",
  "main": "./dist/main.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/main.js",
      "require": "./dist/main.cjs"
    },
    "./exceptions": {
      "types": "./dist/Exceptions.d.ts",
      "import": "./dist/exceptions.js",
      "require": "./dist/exceptions.cjs"
    }
  },
  "pnpm": {
    "overrides": {
      "vite@>=6.0.0 <=6.3.5": ">=6.3.6",
      "js-yaml@>=4.0.0 <4.1.1": ">=4.1.1",
      "lodash-es@>=4.0.0 <=4.17.22": ">=4.17.23",
      "lodash@>=4.0.0 <=4.17.22": ">=4.17.23",
      "axios@<=1.13.4": ">=1.13.5",
      "minimatch@<10.2.1": ">=10.2.1",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "minimatch@>=10.0.0 <10.2.3": ">=10.2.3",
      "ajv@<6.14.0": ">=6.14.0",
      "ajv@>=7.0.0-alpha.0 <8.18.0": ">=8.18.0",
      "flatted@<3.4.0": ">=3.4.0",
      "flatted@<=3.4.1": ">=3.4.2",
      "handlebars@>=4.0.0 <=4.7.8": ">=4.7.9",
      "brace-expansion@>=4.0.0 <5.0.5": ">=5.0.5",
      "handlebars@>=4.0.0 <4.7.9": ">=4.7.9",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "handlebars@>=4.6.0 <=4.7.8": ">=4.7.9",
      "lodash-es@>=4.0.0 <=4.17.23": ">=4.18.0",
      "lodash@>=4.0.0 <=4.17.23": ">=4.18.0",
      "lodash-es@<=4.17.23": ">=4.18.0",
      "lodash@<=4.17.23": ">=4.18.0",
      "vite@>=7.0.0 <=7.3.1": ">=7.3.2",
      "vite@>=7.1.0 <=7.3.1": ">=7.3.2",
      "axios@<1.15.0": ">=1.15.0",
      "follow-redirects@<=1.15.11": ">=1.16.0"
    }
  },
  "types": "./dist/index.d.ts",
  "devDependencies": {
    "@eslint/js": "^9.11.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@stylistic/eslint-plugin-ts": "^2.8.0",
    "@types/eslint__js": "^8.42.3",
    "@types/node": "^24.0.0",
    "@types/qs": "^6.14.0",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.31.0",
    "semantic-release": "^25.0.3",
    "terser": "^5.34.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.7.0",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4",
    "yalc": "1.0.0-pre.53"
  },
  "dependencies": {
    "axios": "^1.12.0",
    "qs": "^6.14.2"
  }
}
